---
interface Props {
  name: string;
  subtitle: string;
  image: string;
  href: string;
  capacity?: string;
}

const { name, subtitle, image, href, capacity } = Astro.props;
---

<a href={href} class="product-card">
  <div class="card-image">
    <img src={image} alt={name} loading="lazy" />
  </div>
  <div class="card-content">
    <h3>{name}</h3>
    <p class="card-subtitle">{subtitle}</p>
    {capacity && <p class="card-capacity">{capacity}</p>}
  </div>
</a>

<style>
  .product-card {
    background: white;
    border: 1px solid var(--color-gray-border);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
    border-color: var(--color-green-light);
  }

  .card-image {
    height: 220px;
    padding: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-image img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: 8px;
    transition: transform 0.3s ease;
  }

  .product-card:hover .card-image img {
    transform: scale(1.03);
  }

  .card-content {
    padding: 1.25rem 1.5rem;
  }

  h3 {
    font-size: 1.2rem;
    color: var(--color-dark);
    margin-bottom: 0.25rem;
  }

  .card-subtitle {
    font-size: 0.85rem;
    color: var(--color-gray);
  }

  .card-capacity {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-green);
    margin-top: 0.5rem;
  }
</style>
