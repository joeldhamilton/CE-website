---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Contact | Circle Energy">
  <Header />
  <main class="contact-page">
    <section class="contact-hero">
      <div class="container">
        <h1>Get In Touch</h1>
        <p>Whether you're exploring your first press or expanding a production line, we're here to help you find the right equipment.</p>
      </div>
    </section>

    <section class="contact-content">
      <div class="container">
        <div class="contact-grid">
          <div class="contact-info">
            <div class="info-card">
              <h2>Contact Information</h2>
              <div class="info-items">
                <div class="info-item">
                  <div class="info-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
                  </div>
                  <div>
                    <p class="info-label">Phone</p>
                    <a href="tel:6085747449" class="info-value">608-574-7449</a>
                  </div>
                </div>

                <div class="info-item">
                  <div class="info-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                  </div>
                  <div>
                    <p class="info-label">Email</p>
                    <a href="mailto:info@circle-energy.com" class="info-value">info@circle-energy.com</a>
                  </div>
                </div>

                <div class="info-item">
                  <div class="info-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                  </div>
                  <div>
                    <p class="info-label">Mailing Address</p>
                    <p class="info-value">PO Box 298<br/>Dodgeville, WI 53533</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="contact-cta">
            <div class="cta-card">
              <h2>Request a Quote</h2>
              <p>Tell us about your operation — what you're pressing, your volume needs, and your goals. We'll recommend the right equipment and provide a detailed quote.</p>
              <a href="mailto:info@circle-energy.com?subject=Quote%20Request" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                Email Us
              </a>
              <a href="tel:6085747449" class="btn btn-secondary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
                Call 608-574-7449
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .contact-page { padding-top: 4rem; }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  .contact-hero {
    padding: 4rem 0 3rem;
    background: var(--color-cream);
    text-align: center;
  }

  .contact-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-dark);
    margin-bottom: 0.75rem;
  }

  .contact-hero p {
    font-size: 1.1rem;
    color: var(--color-gray);
    max-width: 550px;
    margin: 0 auto;
  }

  .contact-content { padding: 4rem 0 6rem; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .info-card {
    border: 1px solid var(--color-gray-border);
    border-radius: 12px;
    padding: 2rem;
  }

  .info-card h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .info-items { display: flex; flex-direction: column; gap: 1.5rem; }

  .info-item { display: flex; gap: 1rem; }

  .info-icon {
    width: 44px;
    height: 44px;
    background: var(--color-green-pale);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-green);
    flex-shrink: 0;
  }

  .info-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gray);
    margin-bottom: 0.15rem;
  }

  .info-value {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-dark);
    display: block;
    line-height: 1.5;
  }

  a.info-value:hover { color: var(--color-green); }

  .cta-card {
    background: var(--color-green-dark);
    border-radius: 16px;
    padding: 2.5rem;
  }

  .cta-card h2 { font-size: 1.75rem; color: white; margin-bottom: 0.75rem; }
  .cta-card > p { font-size: 0.95rem; color: rgba(255,255,255,0.7); line-height: 1.7; margin-bottom: 2rem; }

  .btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    padding: 1rem;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 10px;
    transition: all 0.2s ease;
    margin-bottom: 0.75rem;
  }

  .btn-primary { background: white; color: var(--color-green-dark); }
  .btn-primary:hover { background: var(--color-green-pale); transform: translateY(-1px); }

  .btn-secondary { background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.2); }
  .btn-secondary:hover { background: rgba(255,255,255,0.2); transform: translateY(-1px); }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
