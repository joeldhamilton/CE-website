---
import ProductLayout from '../../layouts/ProductLayout.astro';
const base = import.meta.env.BASE_URL;
---

<ProductLayout
  name="KK100 F Universal"
  subtitle="Production Oil Press"
  image={`${base}/images/kk100.jpg`}
  description="The KK100 delivers up to 220 lb/hr of pressing capacity with the precision and reliability of German engineering."
  specs={[
    { label: "Seed Capacity", value: "up to 100 kg/h (220 lb)" },
    { label: "Engine Power", value: "7.5 kW (10 hp)" },
    { label: "Speed", value: "15–70 RPM" },
    { label: "Voltage Standard", value: "400V-3ph" },
    { label: "Voltage Special", value: "230V-1ph / 208-230V-3ph / 460-480V-3ph" },
    { label: "Dimensions", value: "1710 × 550 × 1230 mm" },
    { label: "Weight", value: "390 kg (860 lb)" },
  ]}
  applications="Amaranth, apricot kernels, avocado, baobab, cotton seeds, fenugreek, borage, coconut/copra, chia, peanut, safflower, pomegranate, rose hip, hemp, hazelnut, jatropha, jojoba, camellia, cherry pits, coriander, pumpkin seeds, gold of pleasure, linseed, lupines, corn germ, almonds, milk thistle, moringa, neem, niger seed, palm kernels, poppy seed, rapeseed, sacha inchi, black cumin, mustard, sesame, soybeans, sunflower seeds, grape seeds, walnut, and more."
