---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const categories = [
  {
    title: 'Oil Presses',
    description: 'The heart of cold-press oil production. From small-batch artisan presses to high-capacity industrial systems, we have a press for every scale.',
    image: `${base}/images/kk500_JPG.jpg`,
    href: `${base}/presses/`,
  },
  {
    title: 'Oil Filters',
    description: 'Crystal-clear oil every time. Our chamber filter presses remove sediment and particles to produce market-ready oil.',
    image: `${base}/images/kkf470-10-3_JPG.jpg`,
    href: `${base}/filters/`,
  },
  {
    title: 'Milling & Processing',
    description: 'Everything you need before and after pressing — dehulling, peeling, toasting, milling, screening, and pelletizing equipment.',
    image: `${base}/images/dehuller.jpg`,
    href: `${base}/milling-equipment/`,
  },
];
---

<Layout title="Circle Energy | Cold-Press Oil Systems">
  <Header />
  <main>
    <section class="hero">
      <div class="hero-content">
        <p class="hero-tag">Cold-Press Oil Systems</p>
        <h1>From Seed to Oil.<br/>Equipment for Every Scale.</h1>
        <p class="hero-sub">US distributor for Kern Kraft oil press systems. Presses, filters, and milling equipment for artisan producers to industrial operations.</p>
        <div class="hero-actions">
          <a href={`${base}/presses/`} class="btn btn-primary">Explore Presses</a>
          <a href={`${base}/contact/`} class="btn btn-secondary">Request a Quote</a>
        </div>
      </div>
      <div class="hero-image">
        <img src={`${base}/images/kk40.jpg`} alt="Kern Kraft KK40 oil press" />
      </div>
    </section>

    <section class="categories">
      <div class="container">
        <div class="section-header">
          <h2>Complete Oil Processing Systems</h2>
          <p>We offer presses for any size of business — plus the filters and milling equipment to build a complete production line.</p>
        </div>
        <div class="cat-grid">
          {categories.map(cat => (
            <a href={cat.href} class="cat-card">
              <div class="cat-image">
                <img src={cat.image} alt={cat.title} loading="lazy" />
              </div>
              <div class="cat-content">
                <h3>{cat.title}</h3>
                <p>{cat.description}</p>
                <span class="cat-link">View Products &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="why">
      <div class="container">
        <div class="section-header">
          <h2>Why Circle Energy?</h2>
        </div>
        <div class="why-grid">
          <div class="why-card">
            <div class="why-number">01</div>
            <h3>German Engineering</h3>
            <p>Kern Kraft presses are precision-built in Germany. Robust construction, reliable performance, and backed by decades of engineering expertise.</p>
          </div>
          <div class="why-card">
            <div class="why-number">02</div>
            <h3>Any Scale</h3>
            <p>From a 3 kg/hr hand press to a 500 kg/hr industrial system — and everything in between. We match the right equipment to your operation.</p>
          </div>
          <div class="why-card">
            <div class="why-number">03</div>
            <h3>Complete Systems</h3>
            <p>Presses, filters, dehullers, peelers, mills, toasters, and screening machines. Build a full production line from a single source.</p>
          </div>
          <div class="why-card">
            <div class="why-number">04</div>
            <h3>US-Based Support</h3>
            <p>Circle Energy is based in Dodgeville, Wisconsin. Local sales, support, and service — no overseas phone calls or time zones.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="used">
      <div class="container">
        <div class="used-inner">
          <h2>Used Equipment</h2>
          <p>We offer used and new equipment on a consignment basis. Looking to buy or sell? Get in touch.</p>
          <a href={`${base}/used-equipment/`} class="btn btn-primary">View Used Equipment</a>
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <div class="cta-inner">
          <h2>Ready to Get Started?</h2>
          <p>Tell us about your operation and we'll recommend the right equipment for your needs.</p>
          <div class="cta-actions">
            <a href={`${base}/contact/`} class="btn btn-primary">Request a Quote</a>
            <a href="tel:6085747449" class="btn btn-outline">Call 608-574-7449</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 85vh;
    padding-top: 4rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 2rem 4rem 4rem;
    max-width: 700px;
    margin-left: auto;
  }

  .hero-tag {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-green);
    margin-bottom: 1rem;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    color: var(--color-dark);
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--color-gray);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .hero-image { overflow: hidden; }
  .hero-image img { width: 100%; height: 100%; object-fit: cover; }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.85rem 2rem;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .btn-primary { background: var(--color-green); color: white; }
  .btn-primary:hover { background: var(--color-green-dark); transform: translateY(-1px); }

  .btn-secondary { background: white; color: var(--color-dark); border: 1px solid var(--color-gray-border); }
  .btn-secondary:hover { border-color: var(--color-green); color: var(--color-green); }

  .btn-outline { color: white; border: 1px solid rgba(255,255,255,0.3); background: rgba(255,255,255,0.1); }
  .btn-outline:hover { background: rgba(255,255,255,0.2); }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  .section-header { text-align: center; margin-bottom: 3rem; }
  .section-header h2 { font-size: clamp(2rem, 4vw, 2.75rem); color: var(--color-dark); margin-bottom: 0.75rem; }
  .section-header p { font-size: 1.05rem; color: var(--color-gray); max-width: 600px; margin: 0 auto; }

  .categories { padding: 6rem 0; background: var(--color-cream); }

  .cat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }

  .cat-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-gray-border);
    transition: all 0.3s ease;
  }

  .cat-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.08); border-color: var(--color-green-light); }

  .cat-image {
    aspect-ratio: 16/10;
    overflow: hidden;
    background: var(--color-gray-light);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .cat-image img { max-height: 100%; object-fit: contain; }

  .cat-content { padding: 1.5rem; }
  .cat-content h3 { font-size: 1.3rem; color: var(--color-dark); margin-bottom: 0.5rem; }
  .cat-content p { font-size: 0.9rem; color: var(--color-gray); line-height: 1.6; margin-bottom: 1rem; }
  .cat-link { font-size: 0.85rem; font-weight: 600; color: var(--color-green); }

  .why { padding: 6rem 0; }
  .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; }
  .why-card { padding: 1.5rem; }
  .why-number { font-family: var(--font-heading); font-size: 2rem; color: var(--color-green-light); margin-bottom: 0.75rem; opacity: 0.5; }
  .why-card h3 { font-family: var(--font-body); font-size: 1.05rem; font-weight: 700; color: var(--color-dark); margin-bottom: 0.5rem; }
  .why-card p { font-size: 0.88rem; color: var(--color-gray); line-height: 1.6; }

  .used { padding: 4rem 0; }
  .used-inner { background: var(--color-cream); border: 1px solid var(--color-gray-border); border-radius: 16px; padding: 3rem; text-align: center; }
  .used-inner h2 { font-size: 1.75rem; margin-bottom: 0.5rem; }
  .used-inner p { color: var(--color-gray); margin-bottom: 1.5rem; }

  .cta { padding: 6rem 0; }
  .cta-inner { background: var(--color-green-dark); border-radius: 16px; padding: 4rem; text-align: center; }
  .cta-inner h2 { font-size: 2rem; color: white; margin-bottom: 0.75rem; }
  .cta-inner p { color: rgba(255,255,255,0.7); margin-bottom: 2rem; font-size: 1.05rem; }
  .cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 1024px) {
    .cat-grid { grid-template-columns: 1fr; max-width: 500px; margin: 0 auto; }
    .why-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-content { padding: 6rem 2rem 3rem; max-width: 100%; }
    .hero-image { max-height: 400px; }
    .why-grid { grid-template-columns: 1fr; }
    .cta-inner { padding: 3rem 2rem; }
  }
</style>
